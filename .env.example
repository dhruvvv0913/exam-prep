# Copy this file to ".env" and fill in your values (Vite exposes VITE_* to the app).
# Get these from your Supabase project: Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The single email address that gets admin powers (library management).
VITE_ADMIN_EMAIL=you@example.com

# Google Gemini key (free tier: https://aistudio.google.com/apikey). NOT VITE_-
# prefixed — must stay server-side. Used locally by scripts/llm-group.mjs, and
# set in Vercel project env so the /api/group function can do AI grouping for
# signed-in users. (Optional: GEMINI_MODEL, defaults to gemini-2.0-flash.)
GEMINI_API_KEY=your-gemini-key

# Service-role secret (Supabase → Settings → API). Local ONLY (bypasses RLS) —
# used by scripts/publish-library.mjs and seed scripts. Never commit/ship it.
SUPABASE_SERVICE_KEY=your-service-role-secret
